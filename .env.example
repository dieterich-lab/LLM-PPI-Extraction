# ── LINDA-LLM Environment Configuration ──────────────────────────────────
# Copy to .env and adjust paths for your environment.
# All paths are absolute; relative paths are resolved against the repo root.

# Core project directories
LINDA_LLM_PROJECT_ROOT=/absolute/path/to/LLM-PPI-Extraction
LINDA_LLM_OUTPUT_ROOT=/absolute/path/to/outputs
LINDA_LLM_TRIPLES_ROOT=/absolute/path/to/outputs/triples
LINDA_LLM_REGULATOME_ROOT=/absolute/path/to/RegulaTome
LINDA_LLM_RESOURCES_ROOT=/absolute/path/to/resources

# External data sources
LINDA_LLM_CARDIAC_DATA=/absolute/path/to/cardiac/abstracts/src
LINDA_LLM_REGULATOME_SRC=/absolute/path/to/RegulaTome/test_ppi_annotations/regulatome_extraction_13_12_2024/src
LINDA_LLM_STRING_PATH=/absolute/path/to/string_ppi.tsv
LINDA_LLM_SPACY_PPI_DIR=/absolute/path/to/spacy/ppi/output

# SLURM / HPC (used by slurm scripts)
LINDA_LLM_PYTHON_VENV=/absolute/path/to/python/venv
LINDA_LLM_SLURM_LOG_DIR=/absolute/path/to/outputs/slurm

# Optional: cache lock timeout in seconds (default: 600)
# LINDA_CACHE_LOCK_TIMEOUT=600

# Optional: override paper source directory (bypasses --data)
# LINDA_LLM_PAPER_PATH_OVERRIDE=/absolute/path/to/papers
